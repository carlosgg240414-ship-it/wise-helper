--  AUTO GRAB instant
-- ════════════════════════════════════════════
local InstantCache={}
local function buildInstantCbs(pr)
    if InstantCache[pr] then return end
    local data={triggerCallbacks={},ready=true}
    local ok,conns=pcall(getconnections,pr.Triggered)
    if ok and type(conns)=="table" then
        for _,c in ipairs(conns) do
            if type(c.Function)=="function" then table.insert(data.triggerCallbacks,c.Function) end
        end
    end
    InstantCache[pr]=data
end
local function instantSteal(pr)
    local d=InstantCache[pr]
    if not d or not d.ready or #d.triggerCallbacks==0 then return end
    d.ready=false
    for _,fn in ipairs(d.triggerCallbacks) do task.spawn(fn) end
    task.wait(0.001); d.ready=true
end
local function startAutoGrab()
    if autoGrabConn then return end
    autoGrabConn=RunService.Heartbeat:Connect(function()
        if not autoGrabEnabled then return end
        local animal=getNearestAnimal(20); if not animal then return end
        local pr=PromptMemoryCache[animal.uid] or findPrompt(animal); if not pr then return end
        buildInstantCbs(pr); instantSteal(pr)
    end)
end
local function stopAutoGrab()
    if autoGrabConn then autoGrabConn:Disconnect(); autoGrabConn=nil end
end

