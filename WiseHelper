    end
end
local function startEspBrainrots()
    if espBrainrotsConn then return end
    espBrainrotsConn=task.spawn(function()
        while espBrainrotsEnabled do
            pcall(updateBrainrotESP)
            task.wait(2)
        end
    end)
end
local function stopEspBrainrots()
    espBrainrotsConn=nil
    local old=PlayerGui:FindFirstChild("WiseHelperBrainrotESP")
    if old then old:Destroy() end
end

