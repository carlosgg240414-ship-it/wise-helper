local KICK_KEYWORD = "you stole"
local function hasKickKeyword(text)
    if typeof(text)~="string" then return false end
    return string.find(string.lower(text), KICK_KEYWORD) ~= nil
end
local function doKick()
    pcall(function() player:Kick("Discord@rznnq") end)
end
local function watchObj(obj)
    if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then return end
    if hasKickKeyword(obj.Text) then doKick(); return end
    local conn=obj:GetPropertyChangedSignal("Text"):Connect(function()
        if hasKickKeyword(obj.Text) then doKick() end
    end)
    table.insert(autoKickConns,conn)
end
local function scanGui(g)
    for _,obj in ipairs(g:GetDescendants()) do watchObj(obj) end
    local conn=g.DescendantAdded:Connect(function(desc) watchObj(desc) end)
    table.insert(autoKickConns,conn)
end
local function startAutoKick()
    for _,g in ipairs(PlayerGui:GetChildren()) do scanGui(g) end
    local conn=PlayerGui.ChildAdded:Connect(function(g) scanGui(g) end)
    table.insert(autoKickConns,conn)
end
local function stopAutoKick()
    for _,c in ipairs(autoKickConns) do pcall(function() c:Disconnect() end) end
    autoKickConns={}
end

